# Copy this file to .env and replace the placeholders locally.
# Never commit the real .env file.

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=iot_user
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=iot_room

# MQTT Broker
MQTT_BROKER=localhost
MQTT_PORT=8899
MQTT_USERNAME=
MQTT_PASSWORD=

# HTTP API
HTTP_HOST=0.0.0.0
HTTP_PORT=8900

# Optional raw TCP transport
TCP_HOST=0.0.0.0
TCP_PORT=8899

# Optional alarm receiver
ALARM_HOST=0.0.0.0
ALARM_PORT=9090

# Optional ZLMediaKit snapshot integration
ZLM_HOST=localhost
ZLM_PORT=80
ZLM_RTSP_PORT=554
ZLM_SECRET=change-me
SNAPSHOT_DIR=snapshots

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/iot_server.log
